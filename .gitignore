*.mov
*.avi
*.mkv
*.wav
*.mp3

# 压缩包
*.zip
*.rar
*.7z
*.tar
*.gz

# 设计文件
*.psd
*.ai
*.sketch

# 其他大文件类型
*.iso
*.dmg
*.exe

